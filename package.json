{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "build": "pnpm --filter './packages/*' build && pnpm --filter './apps/*' build",
    "test": "pnpm --filter './apps/*' --filter '@scout/infra' test",
    "typecheck": "pnpm --filter './packages/*' typecheck && pnpm --filter './apps/*' typecheck && pnpm --filter '@scout/infra' typecheck",
    "lint": "eslint . --max-warnings 0",
    "sandcastle": "pnpm dlx ./sandcastle/main.mts"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "@eslint/js": "^9.28.0",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
